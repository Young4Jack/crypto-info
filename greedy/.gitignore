# --- 系统与编辑器 ---
.DS_Store
.vscode/
.idea/

# 忽略所有层级下的 __pycache__ 文件夹
**/__pycache__/

# 忽略所有 .pyc 编译文件
*.pyc

# --- 后端 (Python/Backend) ---
# 虚拟环境
backend/venv/
# 编译缓存
backend/__pycache__/
backend/*.pyc
# 日志文件
backend/logs/
# 【非常重要】API 密钥和数据库密码
backend/.env

# --- 数据库 (SQLite) ---
# 你的数据文件 crypto.db
backend/*.db
# SQLite WAL 模式临时文件
backend/*.db-shm
backend/*.db-wal
# 备份文件
backend/*.db.bak
# 数据库迁移文件 (建议保留 versions 文件夹，忽略缓存)
backend/alembic/__pycache__/

# --- 前端 (Frontend/Node) ---
# 【体积最大】绝对不要上传
**/node_modules/
# 编译产物
**/dist/
**/.vscode/
**/.env.local
**/.env
**/unpackage/
.env.*

# --- 其他 ---
**/config.json
**.log
temp/
README.md
PROJECT_PLAN.md
ISSUES_LOG.md
docker-compose.yml
.clinerules
.cursor/
AGENTS.md

# --- PID 文件和运行时文件 ---
*.pid
.backend.pid
.proxy.pid
.frontend.pid

# --- Release 构建 ---
release/